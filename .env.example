# Required model configs
DESC_AGENT_MODEL=openai:gpt-4.1-mini
BENCH_AGENT_MODEL=openai:gpt-4.1-mini

# Required provider API key (pick based on provider)
OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# GOOGLE_API_KEY=your_google_key_here

# Optional workflow defaults
DB_DIR=./db
TEMPLATE_DIR=./template
OUTPUT_DIR=./output
BENCH_NUMBER=5
THREADS=1
# Optional: set explicit language (python/cpp/c/java). Leave empty for auto detect by template suffix.
# LANGUAGE=auto
